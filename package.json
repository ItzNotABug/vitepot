{
    "name": "@itznotabug/vitepot",
    "version": "0.0.2",
    "description": "Static-first Vite/VitePress honeypot plugin for serving fake sensitive files to crawlers, scanners, and bots.",
    "type": "module",
    "packageManager": "bun@1.3.12",
    "author": "@itznotabug",
    "license": "Apache-2.0",
    "publishConfig": {
        "access": "public"
    },
    "main": "./dist/vitepot.js",
    "types": "./dist/vitepot.d.ts",
    "exports": {
        ".": {
            "types": "./dist/vitepot.d.ts",
            "import": "./dist/vitepot.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "clean": "rm -rf node_modules && bun install",
        "build": "bun build src/vitepot.ts --outdir dist --target node --format esm && bun run build:types",
        "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
        "test": "bun test",
        "test:watch": "bun test --watch",
        "typecheck": "tsc --noEmit",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "check": "bun run lint && bun run typecheck && bun test",
        "check:fix": "bun run lint:fix && bun run typecheck && bun test"
    },
    "keywords": [
        "vite-plugin",
        "vitepress-plugin",
        "vite",
        "vitepress",
        "static-site",
        "ssg",
        "honeypot",
        "honeypot plugin",
        "deception",
        "bot-trap",
        "crawler-trap",
        "scanner-bait",
        "crawler-deception",
        "bot-deception",
        "fake-sensitive-files",
        "web-security",
        "security-plugin",
        "env-honeypot",
        "wp-config-honeypot",
        "static security",
        "docs security"
    ],
    "dependencies": {
        "@faker-js/faker": "^9.3.0"
    },
    "peerDependencies": {
        "vite": "^5.0.0 || ^6.0.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.12",
        "@types/bun": "^1.3.12",
        "@types/node": "^24.10.11",
        "typescript": "^5.9.3",
        "vite": "^6.3.5"
    }
}
